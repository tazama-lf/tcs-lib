{
"info": {
"_postman_id": "a1b2c3d4-e5f6-7890-1234-567890abcdef",
"name": "DEMS SAMPLE COLLECTION",
"description": "Collection for testing DEMS endpoints with authentication",
"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
},
"item": [
{
"name": "Authentication",
"event": [
{
"listen": "test",
"script": {
"exec": [
"// Extract token from response and set as environment variable",
"if (pm.response.code === 200) {",
"    const responseJson = pm.response.json();",
"    const token = responseJson.token || responseJson.access_token || responseJson.accessToken;",
"    if (token) {",
"        pm.environment.set('bearer_token', token);",
"        console.log('Token saved to environment:', token);",
"    }",
"}"
],
"type": "text/javascript"
}
}
],
"request": {
"method": "POST",
"header": [
{
"key": "Content-Type",
"value": "application/json"
}
],
"body": {
"mode": "raw",
"raw": "{\n  \"username\": \"user\",\n  \"password\": \"user\"\n}"
},
"url": {
"raw": "{{base_url}}/auth/login",
"host": [
"{{base_url}}"
],
"path": [
"auth",
"login"
]
},
"description": "Authenticate user and retrieve bearer token"
},
"response": []
},
{
"name": "API Request with Bearer Token",
"event": [
{
"listen": "prerequest",
"script": {
"exec": [
"// Ensure we have a bearer token",
"const token = pm.environment.get('bearer_token');",
"if (!token) {",
"    console.log('No bearer token found. Please run the Authentication request first.');",
"}"
],
"type": "text/javascript"
}
}
],
"request": {
"auth": {
"type": "bearer",
"bearer": [
{
"key": "token",
"value": "{{bearer_token}}",
"type": "string"
}
]
},
"method": "POST",
"header": [
{
"key": "Content-Type",
"value": "application/json"
}
],
"body": {
"mode": "raw",
"raw": "{\n  \"name\": \"Sample Endpoint\",\n  \"path\": \"/api/sample\",\n  \"method\": \"POST\",\n  \"version\": \"1.0.0\",\n  \"transactionType\": \"Payments\",\n  \"contentType\": \"application/json\",\n  \"samplePayload\": \"{\\\"amount\\\": 100, \\\"currency\\\": \\\"USD\\\", \\\"recipient\\\": \\\"user@example.com\\\"}\",\n  \"description\": \"Sample payment endpoint for testing\"\n}"
},
"url": {
"raw": "{{base_url}}/{{endpoint_path}}",
"host": [
"{{base_url}}"
],
"path": [
"{{endpoint_path}}"
]
},
"description": "Main API request using bearer token authentication with sample payload"
},
"response": []
}
],
"variable": [
{
"key": "base_url",
"value": "http://localhost:3000",
"type": "string"
},
{
"key": "endpoint_path",
"value": "api/endpoints",
"type": "string"
},
{
"key": "bearer_token",
"value": "",
"type": "string"
}
]
}
