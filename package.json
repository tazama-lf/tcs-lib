{
  "name": "@tazama-lf/tcs-lib",
  "version": "1.0.0",
  "description": "A TypeScript package containing interfaces and Data Transfer Objects (DTOs).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "nest build",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "publish:private": "npm publish --access restricted",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "fix:eslint": "eslint --fix \"src/**/*.ts\"",
    "fix:prettier": "prettier --write \"src/**/*.ts\"",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "lint:eslint-unused": "eslint --report-unused-disable-directives \"src/**/*.ts\"",
    "lint:eslint-no-inline": "eslint --no-inline-config \"src/**/*.ts\"",
    "lint:prettier": "prettier --check \"src/**/*.ts\""
  },
  "private": false,
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/my-types-package.git"
  },
  "keywords": [
    "typescript",
    "interfaces",
    "dtos",
    "nestjs",
    "validation"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@nestjs/mapped-types": "^2.1.0",
    "@types/multer": "^2.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "multer": "^2.0.2",
    "reflect-metadata": "^0.1.13",
    "xml2js": "^0.6.2"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10.4.20",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.0.0"
  }
}
